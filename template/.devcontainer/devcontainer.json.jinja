{
  "name": {{ project_name | tojson }},
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "remoteUser": "dev",
  "workspaceFolder": "/workspace",

  "mounts": [
    "source=${localWorkspaceFolderBasename}-claude-config,target=/home/dev/.claude,type=volume",
    "source=${localWorkspaceFolderBasename}-shell-history,target=/commandhistory,type=volume"
  ],

  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/dev/.claude",
    "COLORTERM": "truecolor",
    "DEVCONTAINER": "true",
    // hf_xet's parallel chunked download wedges behind the firewall proxy;
    // force classic single-stream LFS so plugin ONNX model downloads reliably.
    "HF_HUB_DISABLE_XET": "1",
    "HISTFILE": "/commandhistory/.zsh_history",
    "SHELL": "/bin/zsh",
    "TERM": "xterm-256color",
    "TZ": "Europe/Amsterdam"
  },

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },

  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "postCreateCommand": "bash .devcontainer/scripts/post-create.sh",
  "waitFor": "postStartCommand"
}

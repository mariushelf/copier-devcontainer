# Pin the Compose project name so host-side `docker compose` helpers and the
# devcontainer CLI agree on ONE project. Without this, raw `docker compose -f
# .devcontainer/docker-compose.yml` derives the name from the compose file's
# parent dir ("devcontainer"), while the devcontainer CLI uses
# "<workspaceFolderBasename>_devcontainer" — two separate projects, so
# `docker compose ps` showed nothing and `dcdown`/`down -v` targeted an empty
# project. The CLI honors this top-level `name:`, so both converge here.
name: {{ (project_name | lower | regex_replace('[^a-z0-9]+', '-') | regex_replace('^-+|-+$', '')) or 'devcontainer' }}_devcontainer

services:
  dev:
    build:
      context: .
      dockerfile: Dockerfile
      args:
        USER_UID: ${USER_UID:-1000}
        USER_GID: ${USER_GID:-1000}
    volumes:
      - ..:/workspace:bind
      # Isolation overlay — named volume masks .venv so host and container
      # toolchains don't contaminate each other.
      - venv:/workspace/.venv
      # Persist the HuggingFace cache so a plugin's ONNX model (downloaded
      # once, several hundred MB) survives container rebuilds (the cache dir is
      # not otherwise on a volume, so it would be wiped on every rebuild).
      - hf-cache:/home/dev/.cache/huggingface
      # NOTE: do NOT bind-mount /etc/localtime here. Docker resolves symlinks
      # on BOTH endpoints, so host /etc/localtime (→ a regional zone) gets
      # mounted over the container's /usr/share/zoneinfo/Etc/UTC (the target
      # of the image's /etc/localtime symlink) — corrupting the tz database:
      # ZoneInfo("UTC") then reports a non-zero offset. Local time comes from
      # the TZ env var set in devcontainer.json instead.
    cap_add:
      - NET_ADMIN
      - NET_RAW
    env_file:
      - path: .env
        required: false
    user: dev
    # Run tini as PID 1 so orphaned children get reaped. Without this, the
    # `sleep infinity` PID 1 never reaps short-lived processes (plugin
    # indexers, Claude Code helpers), so zombies accumulate over the
    # container's lifetime.
    init: true
    # Keep container running for devcontainer exec
    command: sleep infinity

  # ── PostgreSQL sidecar (uncomment to enable) ────────────────────────
  # To use: uncomment the db service and the depends_on block above,
  # then set DATABASE_URL in the dev service's environment.
  #
  # db:
  #   image: postgres:16
  #   environment:
  #     POSTGRES_USER: dev
  #     POSTGRES_PASSWORD: dev
  #     POSTGRES_DB: app
  #   healthcheck:
  #     test: ["CMD", "pg_isready", "-U", "dev"]
  #     interval: 5s
  #     timeout: 5s
  #     retries: 5
  #   volumes:
  #     - pgdata:/var/lib/postgresql/data

volumes:
  venv:
  hf-cache:
  # pgdata:
